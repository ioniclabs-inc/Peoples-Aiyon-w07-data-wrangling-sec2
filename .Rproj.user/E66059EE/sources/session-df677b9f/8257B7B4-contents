.copy-btn:hover { border-color: var(--lime); color: var(--lime); }
.copy-btn.copied { color: var(--green); border-color: var(--green); }

/* ── Code block ── */
.code-scroll {
  flex: 1;
  overflow: auto;
  padding: 0;
}
.code-scroll pre {
  margin: 0 !important;
  border-radius: 0 !important;
  background: var(--surface) !important;
  padding: 1.5rem !important;
  font-family: 'Fira Code', monospace !important;
  font-size: 0.82rem !important;
  line-height: 1.7 !important;
  tab-size: 4;
}
.hljs { background: var(--surface) !important; }
.hljs-comment { color: #4a5568 !important; font-style: italic; }
.hljs-keyword { color: #c9ff47 !important; }
.hljs-string  { color: #68d391 !important; }
.hljs-number  { color: #f6ad55 !important; }
.hljs-built_in { color: #90cdf4 !important; }
.hljs-title    { color: #b794f4 !important; }
.hljs-decorator { color: #fc8181 !important; }

/* ── Stats row ── */
.stats-row {
  display: flex;
  gap: 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: #0f1012;
}
.stat {
  flex: 1;
  padding: 0.8rem 1.5rem;
  border-right: 1px solid var(--border);
  text-align: center;
}
.stat:last-child { border-right: none; }
.stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--lime);
  display: block;
}
.stat-label {
  font-family: 'Fira Code', monospace;
  font-size: 0.6rem;
  color: var(--muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  display: block;
  margin-top: 0.1rem;
}

/* ── Animations ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
