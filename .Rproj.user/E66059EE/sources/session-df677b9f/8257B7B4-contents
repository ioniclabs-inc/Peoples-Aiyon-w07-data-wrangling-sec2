header, nav, main {
  animation: fadeUp 0.5s ease both;
}
nav { animation-delay: 0.1s; }
main { animation-delay: 0.2s; }

/* ── Footer ── */
footer {
  border-top: 1px solid var(--border);
  padding: 1.5rem 5vw;
  display: flex;
  justify-content: space-between;
  align-items: center;
