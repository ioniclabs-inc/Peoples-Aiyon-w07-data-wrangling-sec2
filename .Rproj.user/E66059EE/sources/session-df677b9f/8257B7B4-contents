<style>
:root {
  --bg:       #0b0c0e;
  --surface:  #131518;
  --border:   #1f2227;
  --lime:     #c9ff47;
  --lime-dim: #8ab52e;
  --text:     #e8eaf0;
  --muted:    #6b7280;
  --red:      #ff5f57;
  --yellow:   #febc2e;
  --green:    #28c840;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Noise overlay ── */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 0; opacity: 0.4;
}

/* ── Header ── */
header {
  position: relative;
  padding: 4rem 5vw 3rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
  overflow: hidden;
}
header::after {
  content: 'PYTHON';
  position: absolute;
  right: -1rem; top: -1.5rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(6rem, 16vw, 14rem);
  font-weight: 900;
  color: transparent;
  -webkit-text-stroke: 1px rgba(201,255,71,0.07);
  pointer-events: none;
  line-height: 1;
  user-select: none;
}
.brand {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(3rem, 8vw, 6rem);
  line-height: 1;
  letter-spacing: -0.02em;
}
.brand span { color: var(--lime); }
.tagline {
  font-family: 'Fira Code', monospace;
  font-size: 0.8rem;
  color: var(--muted);
  margin-top: 0.5rem;
  letter-spacing: 0.05em;
}
.skills-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: flex-end;
}
.skill-tag {
  font-family: 'Fira Code', monospace;
  font-size: 0.7rem;
  padding: 0.3rem 0.7rem;
  border: 1px solid var(--border);
  border-radius: 2px;
  color: var(--muted);
  letter-spacing: 0.05em;
  transition: all 0.2s;
}
.skill-tag.active {
  border-color: var(--lime);
  color: var(--lime);
  background: rgba(201,255,71,0.06);
}

/* ── Nav tabs ── */
nav {
  display: flex;
  gap: 0;
  padding: 0 5vw;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  scrollbar-width: none;
}
nav::-webkit-scrollbar { display: none; }
.tab {
  padding: 1.2rem 1.8rem;
  font-family: 'Fira Code', monospace;
  font-size: 0.78rem;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: all 0.2s;
  letter-spacing: 0.04em;
  position: relative;
}
.tab:hover { color: var(--text); }
.tab.active {
  color: var(--lime);
  border-bottom-color: var(--lime);
}
.tab .dot {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--muted);
  margin-right: 0.5rem;
  vertical-align: middle;
  position: relative; top: -1px;
}
.tab.active .dot { background: var(--lime); box-shadow: 0 0 6px var(--lime); }

/* ── Main layout ── */
main {
  display: grid;
  grid-template-columns: 300px 1fr;
  min-height: calc(100vh - 200px);
}
@media (max-width: 900px) { main { grid-template-columns: 1fr; } }

/* ── Sidebar ── */
aside {
  border-right: 1px solid var(--border);
  padding: 2rem;
  position: sticky;
  top: 0;
  height: fit-content;
  max-height: 100vh;
  overflow-y: auto;
}
.project-meta { margin-bottom: 2rem; }
.meta-label {
  font-family: 'Fira Code', monospace;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.4rem;
}
.meta-value {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.02em;
}
.meta-value.highlight { color: var(--lime); }

.concept-section { margin-top: 1.5rem; }
.concept-title {
  font-family: 'Fira Code', monospace;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}
.concept-item {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
  font-size: 0.82rem;
  color: var(--text);
  opacity: 0.8;
}
.concept-item::before {
  content: '›';
  color: var(--lime);
  flex-shrink: 0;
  font-family: 'Fira Code', monospace;
}

.run-block {
  margin-top: 2rem;
  padding: 1rem;
  background: rgba(201,255,71,0.04);
  border: 1px solid rgba(201,255,71,0.15);
  border-radius: 4px;
