library(ggplot2)
ggplot(mtcars, aes(x = mpg)) +
geom_histogram(binwidth = 3, fill = "#3b82f6", color = "white", alpha = 0.85) +
labs(
title = "Distribution of Miles Per Gallon",
subtitle = "Source: mtcars dataset",
x = "Miles Per Gallon (MPG)",
y = "Count"
) +
theme_minimal(base_size = 13)
